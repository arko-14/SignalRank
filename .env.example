EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
LOCAL_EMBEDDING_LOCAL_FILES_ONLY=true

# Optional OpenRouter settings
OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_EXPLANATIONS_ENABLED=false
OPENROUTER_EXPLANATION_MODEL=openai/gpt-4o-mini
OPENROUTER_CHAT_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TIMEOUT_SECONDS=30

# Memgraph settings
MEMGRAPH_USE=true
MEMGRAPH_HOST=127.0.0.1
MEMGRAPH_PORT=7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=
